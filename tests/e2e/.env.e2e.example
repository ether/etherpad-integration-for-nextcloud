# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Copy this file to tests/e2e/.env.e2e (gitignored) and fill in the
# values for YOUR test Nextcloud instance. Never commit real credentials.
#
# Use a dedicated throwaway test account, not your daily-driver user —
# the E2E specs create and delete .pad files on this instance.

# Base URL of the Nextcloud instance under test (no trailing slash).
E2E_BASE_URL=https://cloud.example.test

# Optional login URL. Defaults to /login for normal Nextcloud instances.
# Use a relative path or a full URL. Useful for instances with social-login
# front doors, for example: /login?noredir=1#body-login
E2E_LOGIN_URL=/login

# Test-account web login (used once by auth.setup.ts to produce a browser
# session; password is never stored in the repo). Nextcloud app passwords
# are intentionally not used for the browser login form.
E2E_USER=e2e-tester
E2E_PASS=change-me

# App password for the same account, used for non-browser WebDAV/API
# setup and teardown. Create one under Settings → Security → Devices &
# sessions, or via `occ user:add-app-password`.
E2E_APP_PASSWORD=change-me-too

# Optional second test account, used only by cross-user permission specs
# (e.g. "user B may not open user A's pad"). Leave unset to skip those
# specs. App password only — these specs only use the OCS/API surface, no
# browser login.
E2E_USER2=
E2E_USER2_APP_PASSWORD=
